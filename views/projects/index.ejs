<%- include('../layouts/header', { title: 'Projects' }) %>
<%- include('../layouts/sidebar') %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.css">
<script src="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.js"></script>

<style>
  :root {
    --primary:       #4361ee;
    --primary-light: #eef0fd;
    --success:       #2ec4b6;
    --success-light: #e6faf8;
    --danger:        #e63946;
    --danger-light:  #fff0f0;
    --warning:       #f4a522;
    --warning-light: #fff8ec;
    --bg:            #f4f5fb;
    --surface:       #ffffff;
    --border:        #e2e5f0;
    --text:          #1e2030;
    --text-muted:    #6b7194;
    --radius:        10px;
    --radius-sm:     7px;
    --shadow-sm:     0 1px 4px rgba(0,0,0,.06);
    --shadow:        0 4px 20px rgba(0,0,0,.08);
  }

  body { background: var(--bg); font-size: 14px; }
  .pg-title { font-size: 1.6rem; font-weight: 700; color: var(--text); letter-spacing: -.4px; }
  .btn-create {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 9px 20px;
    background: var(--primary); color: #fff;
    border: none; border-radius: var(--radius-sm);
    font-size: 13.5px; font-weight: 600;
    cursor: pointer; text-decoration: none;
    transition: all .18s;
    box-shadow: 0 2px 8px rgba(67,97,238,.28);
  }
  .btn-create:hover { background: #3451d1; color: #fff; box-shadow: 0 4px 14px rgba(67,97,238,.38); transform: translateY(-1px); }
  .search-bar { position: relative; max-width: 280px; }
  .search-bar i { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 14px; pointer-events: none; }
  .search-bar input {
    padding-left: 32px; border: 1px solid var(--border);
    border-radius: var(--radius-sm); font-size: 13px; color: var(--text);
    background: var(--surface); width: 100%; height: 36px;
    outline: none; transition: border-color .18s, box-shadow .18s;
  }
  .search-bar input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(67,97,238,.1); }
  .search-bar input::placeholder { color: #b4b9ce; }
  .projects-wrapper {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }


  .project-row {
    display: flex; align-items: center; gap: 16px;
    padding: 18px 20px;
    border-bottom: 1px solid var(--border);
    transition: background .15s;
  }
  .project-row:last-child { border-bottom: none; }
  .project-row:hover { background: #fafbff; }


  .proj-icon {
    width: 48px; height: 48px;
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; font-size: 20px;
  }

  
  .proj-info { flex: 1; min-width: 0; }
  .proj-name { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .proj-meta { font-size: 12.5px; color: var(--text-muted); display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .proj-meta .meta-label { font-weight: 500; }

  .status-badge {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 11px; font-weight: 600; padding: 2px 8px;
    border-radius: 20px; text-transform: uppercase; letter-spacing: .3px;
  }
  .status-active   { background: #e6faf5; color: #0a7a50; border: 1px solid #a0dfc3; }
  .status-inactive { background: #fff0f0; color: #b00020; border: 1px solid #ffb3b3; }

  
  .color-dot {
    width: 10px; height: 10px;
    border-radius: 50%; flex-shrink: 0;
  }

  .proj-actions { display: flex; align-items: center; gap: 4px; flex-shrink: 0; }
  .action-btn {
    width: 34px; height: 34px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface); color: var(--text-muted);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; font-size: 15px; text-decoration: none;
    transition: all .15s;
  }
  .action-btn:hover        { background: var(--primary-light); color: var(--primary); border-color: #c8d0fa; }
  .action-btn.danger:hover { background: var(--danger-light);  color: var(--danger);  border-color: #ffb3b3; }

  .empty-state { padding: 60px 20px; text-align: center; color: var(--text-muted); }
  .empty-state i { font-size: 40px; margin-bottom: 12px; opacity: .4; display: block; }
  .empty-state p { font-size: 14px; margin: 0; }


  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(15,18,40,.45);
    backdrop-filter: blur(3px);
    z-index: 9000;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity .22s;
  }
  .modal-overlay.open { opacity: 1; pointer-events: all; }

  .modal-box {
    background: var(--surface);
    border-radius: var(--radius);
    box-shadow: 0 20px 60px rgba(0,0,0,.18);
    width: 100%; max-width: 480px; margin: 16px;
    transform: translateY(24px) scale(.97);
    transition: transform .25s cubic-bezier(.175,.885,.32,1.275);
    overflow: hidden;
  }
  .modal-overlay.open .modal-box { transform: translateY(0) scale(1); }

  .modal-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    background: #fafbff;
  }
  .modal-head-title {
    font-size: 14.5px; font-weight: 700; color: var(--text);
    display: flex; align-items: center; gap: 8px;
  }
  .modal-close {
    width: 28px; height: 28px;
    border-radius: 6px; border: 1px solid var(--border);
    background: transparent; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: var(--text-muted); font-size: 16px; transition: all .15s;
  }
  .modal-close:hover { background: var(--danger-light); color: var(--danger); border-color: #ffb3b3; }

  .modal-body { padding: 22px; }
  .modal-foot {
    display: flex; align-items: center; justify-content: flex-end; gap: 10px;
    padding: 14px 20px;
    border-top: 1px solid var(--border);
    background: #fafbff;
  }


  .form-group { margin-bottom: 16px; }
  .form-group:last-child { margin-bottom: 0; }

  .form-label-pg {
    display: block;
    font-size: 11.5px; font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase; letter-spacing: .4px;
    margin-bottom: 6px;
  }
  .form-control-pg {
    width: 100%;
    padding: 9px 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: inherit; font-size: 13.5px;
    color: var(--text); background: var(--surface);
    outline: none;
    transition: border-color .18s, box-shadow .18s;
  }
  .form-control-pg:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(67,97,238,.1);
  }
  .form-control-pg::placeholder { color: #b4b9ce; }

  textarea.form-control-pg { resize: vertical; min-height: 80px; line-height: 1.6; }
  .color-picker-row { display: flex; gap: 8px; flex-wrap: wrap; }
  .color-swatch {
    width: 28px; height: 28px; border-radius: 50%;
    border: 2px solid transparent; cursor: pointer;
    transition: transform .15s, border-color .15s;
    flex-shrink: 0;
  }
  .color-swatch:hover   { transform: scale(1.15); }
  .color-swatch.selected { border-color: var(--text); transform: scale(1.1); }
  .btn-pg {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 16px; border-radius: var(--radius-sm);
    font-family: inherit; font-size: 13px; font-weight: 500;
    cursor: pointer; border: none; transition: all .18s;
  }
  .btn-ghost   { background: transparent; border: 1px solid var(--border); color: var(--text-muted); }
  .btn-ghost:hover { background: var(--bg); color: var(--text); }
  .btn-primary { background: var(--primary); color: #fff; box-shadow: 0 2px 8px rgba(67,97,238,.28); }
  .btn-primary:hover { background: #3451d1; }
  .btn-primary:disabled { opacity: .65; cursor: not-allowed; }

  @keyframes pg-spin { to { transform: rotate(360deg); } }
  .spin { animation: pg-spin .7s linear infinite; display: inline-block; }
</style>

<div class="container-fluid mt-4 px-3 px-md-4 pt-4">
  <div class="d-flex justify-content-between align-items-start mb-4 pt-4">
    <div>
      <h2 class="pg-title mb-1">Projects</h2>
      <small class="text-muted">Organise and manage all your projects</small>
    </div>
    <button class="btn-create" onclick="openModal()">
      <i class="bi bi-plus-circle"></i> Create New Project
    </button>
  </div>
  <div class="d-flex align-items-center justify-content-between mb-3">
    <span class="text-muted" style="font-size:13px;">
      <% if (projects && projects.length) { %>
        <strong style="color:var(--text)"><%= projects.length %></strong>
        project<%= projects.length !== 1 ? 's' : '' %> found
      <% } %>
    </span>
    <div class="search-bar">
      <i class="bi bi-search"></i>
      <input type="text" id="searchInput" placeholder="Search projects…" oninput="filterProjects()">
    </div>
  </div>
  <div class="projects-wrapper" id="projectsList">

    <% if (projects && projects.length) { %>
      <% projects.forEach(function(p) { %>
        <div class="project-row" data-name="<%= p.name.toLowerCase() %>">
          <div class="proj-icon" style="background:<%= p.color || '#eef0fd' %>22; border:1px solid <%= p.color || '#c8d0fa' %>44;">
            <i class="bi bi-folder2" style="color:<%= p.color || 'var(--primary)' %>"></i>
          </div>
          <div class="proj-info">
            <div class="proj-name"><a href="/projects/<%= p._id %>" style="color:var(--text);text-decoration:none;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--text)'"><%= p.name %></a></div>
            <div class="proj-meta">
              <% if (p.domain) { %>
                <span style="font-family:'Courier New',monospace;font-size:11.5px;background:var(--bg);border:1px solid var(--border);padding:1px 7px;border-radius:4px;color:var(--text);">
                  <i class="bi bi-globe2" style="font-size:10px;"></i> <%= p.domain %>
                </span>
                <% if (p.domainFilter && p.domainFilter !== 'none') { %>
                  <span style="font-size:11px;font-weight:600;padding:1px 7px;border-radius:20px;<%= p.domainFilter === 'match' ? 'background:#e6faf8;color:#0a7a50;' : 'background:#fff0f0;color:#b00020;' %>">
                    <%= p.domainFilter === 'match' ? '✓ Allow only' : '✕ Block' %>
                  </span>
                <% } %>
                <span style="color:var(--border)">•</span>
              <% } %>
              <% if (p.description) { %>
                <span style="max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= p.description %></span>
                <span style="color:var(--border)">•</span>
              <% } %>
              <% if (typeof p.templateCount !== 'undefined') { %>
                <span><i class="bi bi-file-earmark-check" style="font-size:11px;"></i> <%= p.templateCount %> template<%= p.templateCount !== 1 ? 's' : '' %></span>
                <span style="color:var(--border)">•</span>
              <% } %>
              <span class="meta-label">Created:</span>
              <span><%= new Date(p.createdAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></span>
              <span class="status-badge <%= p.isActive !== false ? 'status-active' : 'status-inactive' %>">
                <i class="bi bi-circle-fill" style="font-size:7px;"></i>
                <%= p.isActive !== false ? 'Active' : 'Inactive' %>
              </span>
            </div>
          </div>
          <div class="proj-actions">
            <a href="/projects/<%= p._id %>" class="action-btn" title="View Templates & Logs"
               style="background:var(--primary-light);color:var(--primary);border-color:#c8d0fa;">
              <i class="bi bi-eye"></i>
            </a>
            <button class="action-btn" title="Edit Project"
                    onclick="openEditModal('<%= p._id %>','<%= p.name.replace(/'/g,`\'`) %>','<%= (p.description||'').replace(/'/g,`\'`) %>','<%= p.color || '#4361ee' %>','<%= p.domain || '' %>','<%= p.domainFilter || 'none' %>')">
              <i class="bi bi-pencil"></i>
            </button>
            <button class="action-btn danger" title="Delete Project"
                    onclick="deleteProject('<%= p._id %>', this)">
              <i class="bi bi-trash"></i>
            </button>
          </div>

        </div>
      <% }) %>
    <% } else { %>
      <div class="empty-state">
        <i class="bi bi-folder-x"></i>
        <p>No projects yet. <a href="#" onclick="openModal()" style="color:var(--primary)">Create your first one →</a></p>
      </div>
    <% } %>

  </div>

</div>
<div class="modal-overlay" id="projectModal" onclick="handleOverlayClick(event)">
  <div class="modal-box">

    <div class="modal-head">
      <div class="modal-head-title">
        <i class="bi bi-folder-plus" style="color:var(--primary)" id="modalIcon"></i>
        <span id="modalTitle">Create New Project</span>
      </div>
      <button class="modal-close" onclick="closeModal()">&#x2715;</button>
    </div>

    <div class="modal-body">
      <div class="form-group">
        <label class="form-label-pg">Project Name <span style="color:var(--danger)">*</span></label>
        <input type="text" id="projName" class="form-control-pg" placeholder="e.g. Contact Us Form, Newsletter…" maxlength="80">
      </div>
      <div class="form-group">
        <label class="form-label-pg">Website Domain</label>
        <input id="projDomain" class="form-control-pg" placeholder="e.g. dynamicssquare.com"
               style="font-family:'Courier New',monospace;font-size:13px;">
        <div style="font-size:11.5px;color:var(--text-muted);margin-top:5px;">
          Domain of the website this project belongs to. Used to filter email log analytics.
        </div>
      </div>

    </div>

    <div class="modal-foot">
      <button class="btn-pg btn-ghost" onclick="closeModal()">Cancel</button>
      <button class="btn-pg btn-primary" id="modalSubmitBtn" onclick="submitProject()">
        <i class="bi bi-check-lg"></i> <span id="modalBtnLabel">Create Project</span>
      </button>
    </div>

  </div>
</div>

<script>
const notyf = new Notyf({ duration: 2500, position: { x:'right', y:'top' }, ripple: false });

let editingId = null;  
function filterProjects() {
  const q    = document.getElementById('searchInput').value.toLowerCase().trim();
  const rows = document.querySelectorAll('.project-row');
  let visible = 0;

  rows.forEach(row => {
    const match = row.dataset.name.includes(q);
    row.style.display = match ? '' : 'none';
    if (match) visible++;
  });

  let noResult = document.getElementById('noSearchResult');
  if (!visible) {
    if (!noResult) {
      noResult = document.createElement('div');
      noResult.id = 'noSearchResult';
      noResult.className = 'empty-state';
      noResult.innerHTML = `<i class="bi bi-search"></i><p>No projects match "<strong>${q}</strong>"</p>`;
      document.getElementById('projectsList').appendChild(noResult);
    }
  } else if (noResult) {
    noResult.remove();
  }
}
function openModal() {
  editingId = null;
  document.getElementById('modalTitle').textContent    = 'Create New Project';
  document.getElementById('modalBtnLabel').textContent = 'Create Project';
  document.getElementById('modalIcon').className       = 'bi bi-folder-plus';
  document.getElementById('projName').value         = '';
  document.getElementById('projDomain').value       = '';
  document.getElementById('projectModal').classList.add('open');
  setTimeout(() => document.getElementById('projName').focus(), 250);
}

function openEditModal(id, name, desc, color, domain = '', domainFilter = 'none') {
  editingId = id;
  document.getElementById('modalTitle').textContent    = 'Edit Project';
  document.getElementById('modalBtnLabel').textContent = 'Save Changes';
  document.getElementById('modalIcon').className       = 'bi bi-pencil-square';
  document.getElementById('projName').value         = name;
  document.getElementById('projDomain').value       = domain;
  document.getElementById('projectModal').classList.add('open');
  setTimeout(() => document.getElementById('projName').focus(), 250);
}

function closeModal() {
  document.getElementById('projectModal').classList.remove('open');
}

function handleOverlayClick(e) {
  if (e.target === document.getElementById('projectModal')) closeModal();
}

async function submitProject() {
  const name  = document.getElementById('projName').value.trim();
  

  if (!name) {
    notyf.error('Project name is required');
    document.getElementById('projName').focus();
    return;
  }

  const btn = document.getElementById('modalSubmitBtn');
  btn.disabled = true;
  btn.innerHTML = `<span class="spin">&#8635;</span> ${editingId ? 'Saving…' : 'Creating…'}`;
  const domain       = document.getElementById('projDomain').value.trim();
  const isEdit = !!editingId;
  const url    = isEdit ? `/projects/update/${editingId}` : '/projects/create';
  const method = isEdit ? 'PUT' : 'POST';

  try {
    const res  = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name,  domain }),
    });
    const data = await res.json();

    if (res.ok && data.success) {
      closeModal();
      notyf.success(isEdit ? 'Project updated!' : 'Project created!');
      setTimeout(() => location.reload(), 600);
    } else {
      notyf.error(data.message || 'Something went wrong');
    }
  } catch {
    notyf.error('Network error. Please try again.');
  } finally {
    btn.disabled = false;
    btn.innerHTML = `<i class="bi bi-check-lg"></i> <span id="modalBtnLabel">${isEdit ? 'Save Changes' : 'Create Project'}</span>`;
  }
}


async function deleteProject(id, btn) {
  if (!confirm('Delete this project? This cannot be undone.')) return;
  try {
    const res  = await fetch(`/projects/delete/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (res.ok && data.success) {
      const row = btn.closest('.project-row');
      row.style.transition = 'opacity .3s, transform .3s';
      row.style.opacity    = '0';
      row.style.transform  = 'translateX(20px)';
      setTimeout(() => {
        row.remove();
        const remaining = document.querySelectorAll('.project-row');
        if (!remaining.length) {
          document.getElementById('projectsList').innerHTML =
            `<div class="empty-state">
               <i class="bi bi-folder-x"></i>
               <p>No projects yet. <a href="#" onclick="openModal()" style="color:var(--primary)">Create your first one →</a></p>
             </div>`;
        }
      }, 300);
      notyf.success('Project deleted');
    } else {
      notyf.error(data.message || 'Failed to delete');
    }
  } catch {
    notyf.error('Something went wrong');
  }
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeModal();
  if (e.key === 'Enter' && document.getElementById('projectModal').classList.contains('open')) {
    if (e.target.tagName !== 'TEXTAREA') submitProject();
  }
});
</script>

<%- include('../layouts/footer') %>
