<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login — MailPortal</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="icon" type="image/x-icon" href="/images/favicon.png">
<style>
  :root {
    --accent:      #4361ee;
    --accent-dark: #3451d1;
    --accent-glow: rgba(67,97,238,.16);
    --danger:      #e8274b;
    --success:     #2ec4b6;
    --ink:         #0d1117;
    --ink-2:       #1c2035;
    --muted:       #7a829e;
    --surface:     #ffffff;
    --bg:          #f0f2f9;
    --border:      #e2e6f0;
    --radius:      16px;
    --radius-sm:   10px;
    --fh:          'Syne', sans-serif;
    --fb:          'DM Sans', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; font-family: var(--fb); font-size: 14px; color: var(--ink); overflow: hidden; }
 
  .page {
    min-height: 100vh; display: flex;
    align-items: center; justify-content: center;
    position: relative; overflow: hidden; background: var(--bg);
  }
  
  .bg-grid {
    position: absolute; inset: 0; pointer-events: none;
    background-image: radial-gradient(circle, rgba(67,97,238,.07) 1px, transparent 1px);
    background-size: 30px 30px;
  }
  .bg-blob {
    position: absolute; border-radius: 50%;
    filter: blur(72px); pointer-events: none;
    animation: blobFloat 9s ease-in-out infinite;
  }
  .b1 { width:520px; height:520px; background:rgba(67,97,238,.11); top:-140px; left:-120px; animation-delay:0s; }
  .b2 { width:420px; height:420px; background:rgba(232,39,75,.07);  bottom:-100px; right:-80px; animation-delay:-4s; }
  .b3 { width:280px; height:280px; background:rgba(46,196,182,.07); top:35%; left:58%; animation-delay:-7s; }
 
  .card {
    position: relative; z-index: 1;
    width: 100%; max-width: 440px; margin: 20px;
    background: var(--surface);
    border-radius: var(--radius); border: 1px solid var(--border);
    box-shadow: 0 2px 4px rgba(0,0,0,.04), 0 20px 60px rgba(67,97,238,.1);
    overflow: hidden;
    animation: cardIn .5s cubic-bezier(.175,.885,.32,1.1) both;
  }
  .card-bar { height: 3px; background: linear-gradient(90deg, #4361ee, #7c3aed, #e8274b); }
  .card-body { padding: 38px 38px 34px; }
 
  .brand {
    display: flex; align-items: center; gap: 10px; margin-bottom: 30px;
    animation: fadeUp .5s .04s ease both; opacity: 0;
  }
  .brand-icon {
    width: 36px; height: 36px; border-radius: 9px; flex-shrink: 0;
    background: linear-gradient(135deg, #4361ee, #7c3aed);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--fh); font-size: 16px; font-weight: 800; color: #fff;
    box-shadow: 0 4px 14px rgba(67,97,238,.32);
  }
  .brand-name { font-family: var(--fh); font-size: 17px; font-weight: 800; color: var(--ink); letter-spacing: -.3px; }
  .brand-name b { color: var(--accent); font-weight: 800; }
  .brand-pill {
    margin-left: auto; font-size: 10px; font-weight: 700; letter-spacing: .6px;
    text-transform: uppercase; color: var(--accent);
    background: var(--accent-glow); border: 1px solid rgba(67,97,238,.18);
    padding: 3px 9px; border-radius: 20px;
  }
 
  .head { margin-bottom: 26px; animation: fadeUp .5s .08s ease both; opacity: 0; }
  .head-title { font-family: var(--fh); font-size: 1.6rem; font-weight: 800; color: var(--ink); letter-spacing: -.5px; margin-bottom: 6px; }
  .head-sub { font-size: 13.5px; color: var(--muted); line-height: 1.6; }

  
  .alert {
    display: none; align-items: flex-start; gap: 9px;
    padding: 10px 13px; border-radius: var(--radius-sm);
    font-size: 13px; font-weight: 500; line-height: 1.5; margin-bottom: 18px;
  }
  .alert.show   { display: flex; }
  .alert.error  { background: #fff0f2; color: #b00028; border: 1px solid #ffd0d8; }
  .alert.ok     { background: #e8fdf8; color: #0a7a50; border: 1px solid #b0e8d8; }
 
  .field { margin-bottom: 17px; animation: fadeUp .5s ease both; opacity: 0; }
  .field:nth-child(1) { animation-delay: .12s; }
  .field:nth-child(2) { animation-delay: .17s; }

  .field-lbl {
    display: block; font-size: 11.5px; font-weight: 700;
    color: var(--ink-2); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 7px;
  }
  .field-wrap { position: relative; }
  .field-ico {
    position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
    color: var(--muted); pointer-events: none; transition: color .2s;
    display: flex; align-items: center;
  }
  .field-wrap:focus-within .field-ico { color: var(--accent); }
  .field-inp {
    width: 100%; padding: 11px 14px 11px 38px;
    border: 1.5px solid var(--border); border-radius: var(--radius-sm);
    font-family: var(--fb); font-size: 14px; color: var(--ink);
    background: #fafbff; outline: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
  }
  .field-inp::placeholder { color: #c2c8d8; }
  .field-inp:focus { border-color: var(--accent); background: #fff; box-shadow: 0 0 0 4px var(--accent-glow); }
  .field-inp.err { border-color: var(--danger); }
  .field-inp.err:focus { box-shadow: 0 0 0 4px rgba(232,39,75,.12); }
  .eye-btn {
    position: absolute; right: 11px; top: 50%; transform: translateY(-50%);
    background: none; border: none; color: var(--muted); cursor: pointer; padding: 3px;
    border-radius: 5px; display: flex; align-items: center; transition: color .15s;
  }
  .eye-btn:hover { color: var(--accent); }

  
  .meta {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px;
    animation: fadeUp .5s .22s ease both; opacity: 0;
  }
  .chk-row { display: flex; align-items: center; gap: 8px; cursor: pointer; user-select: none; }
  .chk-row input { display: none; }
  .chk-box {
    width: 17px; height: 17px; border-radius: 5px; flex-shrink: 0;
    border: 1.5px solid var(--border); background: #fafbff;
    display: flex; align-items: center; justify-content: center; transition: all .15s;
  }
  .chk-row input:checked + .chk-box { background: var(--accent); border-color: var(--accent); }
  .chk-row input:checked + .chk-box::after {
    content: ''; display: block; width: 9px; height: 5px;
    border-left: 2px solid #fff; border-bottom: 2px solid #fff;
    transform: rotate(-45deg) translateY(-1px);
  }
  .chk-lbl { font-size: 13px; color: var(--ink-2); font-weight: 500; }
  .link { font-size: 13px; color: var(--accent); font-weight: 600; text-decoration: none; transition: color .15s; }
  .link:hover { color: var(--accent-dark); }
 
  .btn-sub {
    width: 100%; padding: 13px 20px; margin-bottom: 22px;
    background: linear-gradient(135deg, var(--accent), var(--accent-dark));
    color: #fff; border: none; border-radius: var(--radius-sm);
    font-family: var(--fb); font-size: 15px; font-weight: 700; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    position: relative; overflow: hidden;
    box-shadow: 0 4px 18px rgba(67,97,238,.3);
    transition: transform .2s, box-shadow .2s;
    animation: fadeUp .5s .27s ease both; opacity: 0;
  }
  .btn-sub::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg,rgba(255,255,255,.12),transparent); pointer-events: none; }
  .btn-sub:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 8px 26px rgba(67,97,238,.38); }
  .btn-sub:active:not(:disabled) { transform: translateY(0); }
  .btn-sub:disabled { opacity: .7; cursor: not-allowed; }
  .btn-arrow { transition: transform .2s; }
  .btn-sub:hover:not(:disabled) .btn-arrow { transform: translateX(4px); }
 
  .footer {
    text-align: center; font-size: 13.5px; color: var(--muted);
    animation: fadeUp .5s .3s ease both; opacity: 0;
  }

   
  @keyframes spin { to { transform: rotate(360deg); } }
  .spinner {
    width: 16px; height: 16px; border-radius: 50%;
    border: 2.5px solid rgba(255,255,255,.3); border-top-color: #fff;
    animation: spin .65s linear infinite;
  }
 
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(26px) scale(.97); }
    to   { opacity: 1; transform: translateY(0)    scale(1); }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(13px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes blobFloat {
    0%,100% { transform: translate(0,0)      scale(1); }
    33%      { transform: translate(18px,-18px) scale(1.04); }
    66%      { transform: translate(-14px,14px) scale(.97); }
  }

  @media (max-width: 480px) {
    .card-body { padding: 30px 22px 26px; }
    .head-title { font-size: 1.4rem; }
  }
</style>
</head>
<body>

<div class="page">
  <div class="bg-grid"></div>
  <div class="bg-blob b1"></div>
  <div class="bg-blob b2"></div>
  <div class="bg-blob b3"></div>

  <div class="card">
    <div class="card-bar"></div>
    <div class="card-body">
 
      <div class="brand">
        <div class="brand-icon">M</div>
        <div class="brand-name">Mail<b>Portal</b></div>
         
      </div>
 
      <div class="head">
        <h1 class="head-title">Welcome back 👋</h1>
        <p class="head-sub">Sign in to manage your templates and leads</p>
      </div>
 
      <div class="alert" id="alert">
        <span id="alertIcon"></span>
        <span id="alertMsg"></span>
      </div>
 
      <form id="loginForm" novalidate autocomplete="on">
        <div class="field">
          <label class="field-lbl" for="email">Email Address</label>
          <div class="field-wrap">
            <span class="field-ico">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </span>
            <input type="email" id="email" name="email" class="field-inp"
                   placeholder="you@company.com" autocomplete="email" required>
          </div>
        </div>
        <div class="field">
          <label class="field-lbl" for="password">Password</label>
          <div class="field-wrap">
            <span class="field-ico">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </span>
            <input type="password" id="password" name="password" class="field-inp"
                   placeholder="Enter your password" autocomplete="current-password"
                   style="padding-right:40px;" required>
            <button type="button" class="eye-btn" id="eyeBtn">
              <svg id="eyeIcon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>
        <div class="meta">
          <label class="chk-row">
            <input type="checkbox" id="remember">
            <div class="chk-box"></div>
            <span class="chk-lbl">Remember me</span>
          </label>
          <a href="/forgot" class="link">Forgot password?</a>
        </div>

        <button type="submit" class="btn-sub" id="loginBtn">
          <span id="btnContent" style="display:flex;align-items:center;gap:8px;">
            Sign In <span class="btn-arrow">→</span>
          </span>
        </button>

      </form>

      <div class="footer">
        Don't have an account? <a href="/register" class="link">Create one free →</a>
      </div>

    </div>
  </div>
</div>

<script>
(async () => {
  try {
    const r = await fetch('/auth/me', { credentials: 'include' });
    if (r.ok) { const d = await r.json(); if (d.success) window.location.replace('/dashboard'); }
  } catch {}
})();

document.getElementById('eyeBtn').addEventListener('click', function() {
  const inp  = document.getElementById('password');
  const icon = document.getElementById('eyeIcon');
  const show = inp.type === 'password';
  inp.type = show ? 'text' : 'password';
  icon.innerHTML = show
    ? `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>`
    : `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
});

function showAlert(msg, type = 'error') {
  const el = document.getElementById('alert');
  document.getElementById('alertIcon').textContent = type === 'error' ? '⚠️' : '✅';
  document.getElementById('alertMsg').textContent  = msg;
  el.className = `alert ${type === 'error' ? 'error' : 'ok'} show`;
}
function hideAlert() { document.getElementById('alert').className = 'alert'; }

function setLoading(on) {
  const btn = document.getElementById('loginBtn');
  btn.disabled = on;
  document.getElementById('btnContent').innerHTML = on
    ? `<div class="spinner"></div> Signing in…`
    : `Sign In <span class="btn-arrow">→</span>`;
}

document.getElementById('loginForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  hideAlert();

  const email    = document.getElementById('email').value.trim();
  const password = document.getElementById('password').value;

  if (!email)    { markErr('email');    showAlert('Please enter your email address.');  return; }
  if (!password) { markErr('password'); showAlert('Please enter your password.'); return; }

  setLoading(true);

  try {
    const res  = await fetch('/auth/login', {
      method:      'POST',
      headers:     { 'Content-Type': 'application/json' },
      credentials: 'include',
      body:        JSON.stringify({ email, password }),
    });
    const data = await res.json();

    if (res.ok && data.success) {
      showAlert('Login successful! Redirecting…', 'success');
      setTimeout(() => window.location.replace('/dashboard'), 650);
    } else {
      showAlert(data.message || 'Invalid email or password.');
      setLoading(false);
    }
  } catch {
    showAlert('Network error. Please check your connection.');
    setLoading(false);
  }
});

function markErr(id) { document.getElementById(id)?.classList.add('err'); }

['email', 'password'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', function() {
    this.classList.remove('err');
    hideAlert();
  });
});
</script>

</body>
</html>
