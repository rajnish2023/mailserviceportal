<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reset Password — MailPortal</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --accent:      #4361ee;
    --accent-dark: #3451d1;
    --accent-glow: rgba(67,97,238,.16);
    --danger:      #e8274b;
    --success:     #2ec4b6;
    --ink:         #0d1117;
    --ink-2:       #1c2035;
    --muted:       #7a829e;
    --surface:     #ffffff;
    --bg:          #f0f2f9;
    --border:      #e2e6f0;
    --radius:      16px;
    --radius-sm:   10px;
    --fh:          'Syne', sans-serif;
    --fb:          'DM Sans', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; font-family: var(--fb); font-size: 14px; color: var(--ink); overflow: hidden; }

  .page { min-height:100vh; display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden; background:var(--bg); }
  .bg-grid { position:absolute; inset:0; pointer-events:none; background-image:radial-gradient(circle,rgba(67,97,238,.07) 1px,transparent 1px); background-size:30px 30px; }
  .bg-blob { position:absolute; border-radius:50%; filter:blur(72px); pointer-events:none; animation:blobFloat 9s ease-in-out infinite; }
  .b1 { width:520px; height:520px; background:rgba(67,97,238,.11); top:-140px; left:-120px; }
  .b2 { width:420px; height:420px; background:rgba(232,39,75,.07); bottom:-100px; right:-80px; animation-delay:-4s; }
  .b3 { width:280px; height:280px; background:rgba(46,196,182,.07); top:35%; left:58%; animation-delay:-7s; }

  .card { position:relative; z-index:1; width:100%; max-width:440px; margin:20px; background:var(--surface); border-radius:var(--radius); border:1px solid var(--border); box-shadow:0 2px 4px rgba(0,0,0,.04),0 20px 60px rgba(67,97,238,.1); overflow:hidden; animation:cardIn .5s cubic-bezier(.175,.885,.32,1.1) both; }
  .card-bar { height:3px; background:linear-gradient(90deg,#4361ee,#7c3aed,#e8274b); }
  .card-body { padding:38px 38px 34px; }

  .brand { display:flex; align-items:center; gap:10px; margin-bottom:28px; animation:fadeUp .5s .04s ease both; opacity:0; }
  .brand-icon { width:36px; height:36px; border-radius:9px; flex-shrink:0; background:linear-gradient(135deg,#4361ee,#7c3aed); display:flex; align-items:center; justify-content:center; font-family:var(--fh); font-size:16px; font-weight:800; color:#fff; box-shadow:0 4px 14px rgba(67,97,238,.32); }
  .brand-name { font-family:var(--fh); font-size:17px; font-weight:800; color:var(--ink); letter-spacing:-.3px; }
  .brand-name b { color:var(--accent); font-weight:800; }
  .brand-pill { margin-left:auto; font-size:10px; font-weight:700; letter-spacing:.6px; text-transform:uppercase; color:var(--accent); background:var(--accent-glow); border:1px solid rgba(67,97,238,.18); padding:3px 9px; border-radius:20px; }

  .ico-wrap { width:60px; height:60px; border-radius:50%; margin:0 auto 18px; background:linear-gradient(135deg,#eef0fd,#f3eeff); border:1.5px solid rgba(67,97,238,.18); display:flex; align-items:center; justify-content:center; animation:fadeUp .5s .07s ease both; opacity:0; }

  .head { text-align:center; margin-bottom:24px; animation:fadeUp .5s .1s ease both; opacity:0; }
  .head-title { font-family:var(--fh); font-size:1.5rem; font-weight:800; color:var(--ink); letter-spacing:-.5px; margin-bottom:7px; }
  .head-sub { font-size:13.5px; color:var(--muted); line-height:1.65; }

  .alert { display:none; align-items:flex-start; gap:9px; padding:10px 13px; border-radius:var(--radius-sm); font-size:13px; font-weight:500; line-height:1.5; margin-bottom:18px; }
  .alert.show  { display:flex; }
  .alert.error { background:#fff0f2; color:#b00028; border:1px solid #ffd0d8; }
  .alert.ok    { background:#e8fdf8; color:#0a7a50; border:1px solid #b0e8d8; }

  .field { margin-bottom:17px; animation:fadeUp .5s ease both; opacity:0; }
  .field:nth-child(1) { animation-delay:.12s; }
  .field:nth-child(2) { animation-delay:.17s; }
  .field-lbl { display:block; font-size:11.5px; font-weight:700; color:var(--ink-2); text-transform:uppercase; letter-spacing:.5px; margin-bottom:7px; }
  .field-wrap { position:relative; }
  .field-ico { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--muted); pointer-events:none; transition:color .2s; display:flex; align-items:center; }
  .field-wrap:focus-within .field-ico { color:var(--accent); }
  .field-inp { width:100%; padding:11px 38px 11px 38px; border:1.5px solid var(--border); border-radius:var(--radius-sm); font-family:var(--fb); font-size:14px; color:var(--ink); background:#fafbff; outline:none; transition:border-color .2s,box-shadow .2s,background .2s; }
  .field-inp::placeholder { color:#c2c8d8; }
  .field-inp:focus { border-color:var(--accent); background:#fff; box-shadow:0 0 0 4px var(--accent-glow); }
  .field-inp.err { border-color:var(--danger); }
  .eye-btn { position:absolute; right:11px; top:50%; transform:translateY(-50%); background:none; border:none; color:var(--muted); cursor:pointer; padding:3px; border-radius:5px; display:flex; align-items:center; transition:color .15s; }
  .eye-btn:hover { color:var(--accent); }
 
  .strength-wrap { margin-top:8px; }
  .strength-bar { height:4px; border-radius:10px; background:var(--border); overflow:hidden; margin-bottom:4px; }
  .strength-fill { height:100%; border-radius:10px; width:0; transition:width .3s,background .3s; }
  .strength-label { font-size:11.5px; color:var(--muted); }

  .btn-sub { width:100%; padding:13px 20px; margin-bottom:22px; background:linear-gradient(135deg,var(--accent),var(--accent-dark)); color:#fff; border:none; border-radius:var(--radius-sm); font-family:var(--fb); font-size:15px; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; position:relative; overflow:hidden; box-shadow:0 4px 18px rgba(67,97,238,.3); transition:transform .2s,box-shadow .2s; animation:fadeUp .5s .22s ease both; opacity:0; }
  .btn-sub::after { content:''; position:absolute; inset:0; background:linear-gradient(180deg,rgba(255,255,255,.12),transparent); pointer-events:none; }
  .btn-sub:hover:not(:disabled) { transform:translateY(-2px); box-shadow:0 8px 26px rgba(67,97,238,.38); }
  .btn-sub:active:not(:disabled) { transform:translateY(0); }
  .btn-sub:disabled { opacity:.7; cursor:not-allowed; }

  .footer { text-align:center; font-size:13.5px; color:var(--muted); animation:fadeUp .5s .25s ease both; opacity:0; }
  .link { color:var(--accent); font-weight:600; text-decoration:none; transition:color .15s; }
  .link:hover { color:var(--accent-dark); }
 
  .success { display:none; text-align:center; animation:fadeUp .4s ease both; }
  .success.show { display:block; }
  .success-ico { width:64px; height:64px; border-radius:50%; margin:0 auto 18px; background:linear-gradient(135deg,#e8fdf8,#d0f7f0); border:1.5px solid #a0dfc3; font-size:28px; display:flex; align-items:center; justify-content:center; }
  .success-title { font-family:var(--fh); font-size:1.3rem; font-weight:800; color:var(--ink); margin-bottom:10px; }
  .success-msg { font-size:13.5px; color:var(--muted); line-height:1.7; margin-bottom:24px; }
  .btn-login { display:inline-flex; align-items:center; gap:8px; padding:12px 28px; border-radius:var(--radius-sm); font-family:var(--fb); font-size:14px; font-weight:700; background:linear-gradient(135deg,var(--accent),var(--accent-dark)); color:#fff; border:none; cursor:pointer; text-decoration:none; box-shadow:0 4px 16px rgba(67,97,238,.3); transition:all .2s; }
  .btn-login:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(67,97,238,.38); color:#fff; }

  @keyframes spin { to { transform:rotate(360deg); } }
  .spinner { width:16px; height:16px; border-radius:50%; border:2.5px solid rgba(255,255,255,.3); border-top-color:#fff; animation:spin .65s linear infinite; }
  @keyframes cardIn { from { opacity:0; transform:translateY(26px) scale(.97); } to { opacity:1; transform:translateY(0) scale(1); } }
  @keyframes fadeUp { from { opacity:0; transform:translateY(13px); } to { opacity:1; transform:translateY(0); } }
  @keyframes blobFloat { 0%,100% { transform:translate(0,0) scale(1); } 33% { transform:translate(18px,-18px) scale(1.04); } 66% { transform:translate(-14px,14px) scale(.97); } }

  @media (max-width:480px) { .card-body { padding:30px 22px 26px; } .head-title { font-size:1.3rem; } }
</style>
</head>
<body>

<div class="page">
  <div class="bg-grid"></div>
  <div class="bg-blob b1"></div>
  <div class="bg-blob b2"></div>
  <div class="bg-blob b3"></div>

  <div class="card">
    <div class="card-bar"></div>
    <div class="card-body">

      <div class="brand">
        <div class="brand-icon">M</div>
        <div class="brand-name">Mail<b>Portal</b></div>
         
      </div>
 
      <div id="formSection">

        <div class="ico-wrap">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#4361ee" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>

        <div class="head">
          <h1 class="head-title">Create new password</h1>
          <p class="head-sub">Must be at least 8 characters. Choose something strong.</p>
        </div>

        <div class="alert" id="alert">
          <span id="alertIcon"></span>
          <span id="alertMsg"></span>
        </div>

        <form id="resetForm" novalidate>
        
          <input type="hidden" id="resetToken" value="<%= locals.resetToken || locals.token || '' %>">
 
          <div class="field">
            <label class="field-lbl" for="password">New Password</label>
            <div class="field-wrap">
              <span class="field-ico">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </span>
              <input type="password" id="password" class="field-inp"
                     placeholder="Min. 8 characters" style="padding-right:40px;" required>
              <button type="button" class="eye-btn" onclick="toggleEye('password', this)">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                </svg>
              </button>
            </div>
       
            <div class="strength-wrap">
              <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
              <span class="strength-label" id="strengthLabel"></span>
            </div>
          </div>
 
          <div class="field">
            <label class="field-lbl" for="confirm">Confirm Password</label>
            <div class="field-wrap">
              <span class="field-ico">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                </svg>
              </span>
              <input type="password" id="confirm" class="field-inp"
                     placeholder="Re-enter your password" style="padding-right:40px;" required>
              <button type="button" class="eye-btn" onclick="toggleEye('confirm', this)">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                </svg>
              </button>
            </div>
          </div>

          <button type="submit" class="btn-sub" id="submitBtn">
            <span id="btnContent" style="display:flex;align-items:center;gap:8px;">
              Reset Password <span>→</span>
            </span>
          </button>
        </form>

        <div class="footer">
          Remember it? <a href="/" class="link">Back to Login</a>
        </div>

      </div>
 
      <div class="success" id="successSection">
        <div class="success-ico">✅</div>
        <div class="success-title">Password updated!</div>
        <p class="success-msg">Your password has been reset successfully.<br>You can now sign in with your new password.</p>
        <a href="/" class="btn-login">Go to Login →</a>
      </div>

    </div>
  </div>
</div>

<script>
 
function showAlert(msg, type = 'error') {
  const el = document.getElementById('alert');
  document.getElementById('alertIcon').textContent = type === 'error' ? '⚠️' : '✅';
  document.getElementById('alertMsg').textContent  = msg;
  el.className = `alert ${type === 'error' ? 'error' : 'ok'} show`;
}
function hideAlert() { document.getElementById('alert').className = 'alert'; }
 
function setLoading(on) {
  const btn = document.getElementById('submitBtn');
  btn.disabled = on;
  document.getElementById('btnContent').innerHTML = on
    ? `<div class="spinner"></div> Resetting…`
    : `Reset Password <span>→</span>`;
}

 
function toggleEye(id, btn) {
  const inp  = document.getElementById(id);
  const icon = btn.querySelector('svg');
  const show = inp.type === 'password';
  inp.type = show ? 'text' : 'password';
  icon.innerHTML = show
    ? `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>`
    : `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
}

 
document.getElementById('password').addEventListener('input', function() {
  const v     = this.value;
  const fill  = document.getElementById('strengthFill');
  const label = document.getElementById('strengthLabel');
  let   score = 0;
  if (v.length >= 8)             score++;
  if (/[A-Z]/.test(v))           score++;
  if (/[0-9]/.test(v))           score++;
  if (/[^A-Za-z0-9]/.test(v))   score++;

  const map = [
    { w: '0%',   bg: '',          txt: '' },
    { w: '25%',  bg: '#e8274b',   txt: '⚠ Weak' },
    { w: '50%',  bg: '#f4a522',   txt: '◑ Fair' },
    { w: '75%',  bg: '#4361ee',   txt: '▲ Good' },
    { w: '100%', bg: '#2ec4b6',   txt: '✓ Strong' },
  ];
  fill.style.width      = map[score].w;
  fill.style.background = map[score].bg;
  label.textContent     = map[score].txt;
  label.style.color     = map[score].bg || 'var(--muted)';
  this.classList.remove('err');
  hideAlert();
});

document.getElementById('confirm').addEventListener('input', function() {
  this.classList.remove('err'); hideAlert();
});
 
document.getElementById('resetForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  hideAlert();
 
  let token = document.getElementById('resetToken').value;
  if (!token) {
     
    const urlParts = window.location.pathname.split('/');
    token = urlParts[urlParts.length - 1] || '';
  }
  const password = document.getElementById('password').value;
  const confirm  = document.getElementById('confirm').value;

  if (!token) {
    showAlert('Reset link is invalid. Please request a new one.', 'error');
    return;
  }
  if (!password) { document.getElementById('password').classList.add('err'); showAlert('Please enter a new password.'); return; }
  if (password.length < 8) { document.getElementById('password').classList.add('err'); showAlert('Password must be at least 8 characters.'); return; }
  if (!confirm) { document.getElementById('confirm').classList.add('err'); showAlert('Please confirm your password.'); return; }
  if (password !== confirm) { document.getElementById('confirm').classList.add('err'); showAlert('Passwords do not match.'); return; }

  setLoading(true);

  try {
    const res  = await fetch('/auth/reset-password', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ token, password, confirmPassword: confirm }),
    });
    const data = await res.json();

    if (res.ok && data.success) {
      document.getElementById('formSection').style.display = 'none';
      document.getElementById('successSection').classList.add('show');
    } else {
      showAlert(data.message || 'Something went wrong. Please try again.');
      setLoading(false);
    }
  } catch {
    showAlert('Network error. Please check your connection.');
    setLoading(false);
  }
});
</script>

</body>
</html>
